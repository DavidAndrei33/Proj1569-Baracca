# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=rotiserie
DB_PASSWORD=rotiserie_secret
DB_NAME=rotiserie
DATABASE_URL=postgresql://rotiserie:rotiserie_secret@localhost:5433/rotiserie?schema=public
DIRECT_URL=postgresql://rotiserie:rotiserie_secret@localhost:5433/rotiserie?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (change in production!)
JWT_SECRET=change-this-to-a-256-bit-secret-key-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Server
NODE_ENV=development
PORT=5002
HOST=0.0.0.0

# CORS
# For dev: http://localhost:3000,http://localhost:3001
# For production (same domain via Caddy): set to "*" or your domain
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=./uploads

# Stripe (optional - leave empty to disable payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=ron
