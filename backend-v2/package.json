{
  "name": "rotiserie-backend-v2",
  "version": "2.0.0",
  "description": "Rotiserie Moinesti Backend v2 - Fastify + Prisma + PostgreSQL + Redis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "pm2 start dist/server.js -i max --name rotiserie-backend-v2",
    "stop:prod": "pm2 stop rotiserie-backend-v2",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "fastify",
    "prisma",
    "postgresql",
    "redis",
    "typescript"
  ],
  "author": "Rotiserie Moinesti",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^5.15.0",
    "@types/bcryptjs": "^3.0.0",
    "argon2": "^0.41.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.33.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "artillery": "^2.0.30",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "prisma": "^5.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
